    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@doubloon/core": "workspace:*"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
