{
  "name": "@doubloon/anchor",
  "version": "0.2.0",
  "description": "Supabase entitlement destination for Doubloon — stores entitlements as rows with full metadata (expiry, source, revocation)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
